package simd_flex

import (
	"fmt"
	"simd_flex/simd"
)

// A SIMD-dependent type alias
type MyInt8s = simd.Int8s

// A struct dependent on SIMD
type VectorC struct {
	Data simd.Float64s
}

// A SIMD-dependent global variable
var ZeroVec simd.Int32s

// A function using SIMD types directly (should be rewritten)
func Add(a, b simd.Int32s) simd.Int32s {
	// Simple mock body, logic doesn't matter for rewrite test
	return a
}

// A function using dependent types (should be rewritten)
func Process(v VectorC) {
	fmt.Println(v)
}

// A dependent function with a standard signature (should generate dispatcher?)
// Wait, instructions say: "if the caller is not itself simd-dependent... the original called function... is rewritten to dispatch"
// AND "if the called simd-dependent function... does not have a simd-dependent type as part of its signature".
// `Add` HAS simd-dependent signature. `Process` HAS simd-dependent signature.
// We need a function that uses SIMD internally but EXPOSES standard types.

func ComputeSum(n int) int {
	// Uses SIMD internally
	var v simd.Int32s
	_ = v

	return n * 2
}

// Real logic would do something.

// Another test: Caller that is NOT dependent calls one that IS dependent.
func MainCaller() {
	res := ComputeSum(10)
	fmt.Println(res)
}
